# Linear OAuth App (create at Linear → Settings → API → OAuth Applications)
LINEAR_CLIENT_ID=your-client-id
LINEAR_CLIENT_SECRET=your-client-secret
LINEAR_REDIRECT_URI=https://repo-agent-linear-bot.onrender.com/callback

# Linear Webhook
LINEAR_WEBHOOK_SECRET=your-signing-secret

# App-actor token (set once after completing OAuth install)
LINEAR_APP_ACCESS_TOKEN=

# Fallback personal key (used if no app token)
LINEAR_API_KEY=lin_api_your-key

# RAG Backend
RAG_BACKEND_URL=https://your-rag-backend.onrender.com

# Optional: override repos.json via env var (JSON string)
# REPOS_JSON={"my-repo":{"url":"https://github.com/org/repo","qdrant_name":"my-repo"}}
